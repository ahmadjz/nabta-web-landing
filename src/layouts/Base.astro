---
import "../styles/global.css";
// Self-hosted fonts (no Google-Fonts CDN). Vite bundles the woff2 into _astro/
// and base-prefixes the URLs automatically. Subset-scoped (arabic-*/latin-*) keeps
// the payload down; @fontsource ships font-display: swap by default — keep it.
// Body: Cairo (ar+latin). Display: Fraunces Variable (Latin) + Tajawal (Arabic).
import "@fontsource/cairo/arabic-400.css";
import "@fontsource/cairo/arabic-500.css";
import "@fontsource/cairo/arabic-700.css";
import "@fontsource/cairo/latin-400.css";
import "@fontsource/cairo/latin-500.css";
import "@fontsource/cairo/latin-700.css";
import "@fontsource-variable/fraunces"; // Latin display (variable weight axis)
import "@fontsource/tajawal/arabic-500.css";
import "@fontsource/tajawal/arabic-700.css";
import "@fontsource/tajawal/arabic-800.css";

import { DIR, getDict, type Locale } from "../i18n";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  /** Page-pair key (drives the language toggle + hreflang). "notfound" has no pair. */
  pageKey: string;
  /** The page's locale — passed explicitly so html lang/dir is deterministic. */
  locale: Locale;
  title: string;
  description: string;
  noindex?: boolean;
}

const { pageKey, locale, title, description, noindex = false } = Astro.props;
const dir = DIR[locale];
const t = getDict(locale);
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <BaseHead
      pageKey={pageKey}
      locale={locale}
      title={title}
      description={description}
      noindex={noindex}
    />
  </head>
  <body class="flex min-h-screen flex-col antialiased">
    <a
      href="#main"
      class="sr-only rounded-md bg-primary px-4 py-2 text-white focus:not-sr-only focus:absolute focus:start-4 focus:top-4 focus:z-50"
    >
      {t.skipToContent}
    </a>
    <Header locale={locale} pageKey={pageKey} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    {
      /* Motion machinery — bundled to same-origin /_astro (module, deferred). Both
       re-init on `astro:page-load`, so reveals re-fire after a ClientRouter swap
       (LVR-03). Inert until a section emits [data-reveal]/[data-count-up]. */
    }
    <script>
      import "../scripts/reveal.ts";
      import "../scripts/count-up.ts";
    </script>
  </body>
</html>
