---
/**
 * Shared layout for the four legal pages (privacy + terms × ar/en), so all four
 * stay structurally identical and the per-page files are thin (locale + which
 * doc). STRUCTURE-only parity: both locales render the same section headings; the
 * body is the shared `todoNote` placeholder until legal supplies binding text.
 *
 * One `LEGAL_IS_DRAFT` flag drives the DRAFT banner + the `noindex` meta (passed
 * to <BaseHead> via Base) here; the sitemap-exclusion half lives in
 * astro.config.mjs, fed by the same flag.
 */
import Base from "../layouts/Base.astro";
import DraftBanner from "./DraftBanner.astro";
import Reveal from "./Reveal.astro";
import { getDict, type Locale } from "../i18n";
import { CONTACT_EMAIL } from "../config";
import { LEGAL_IS_DRAFT } from "../config/legal";

interface Props {
  locale: Locale;
  /** Which legal document — also the page-pair key for hreflang/toggle. */
  doc: "privacy" | "terms";
}

const { locale, doc } = Astro.props;
const t = getDict(locale);
const tl = t.legal;
const title = t.nav[doc]; // reuse the chrome label ("Privacy Policy"/"Terms…")
const { sections } = tl[doc];
---

<Base
  pageKey={doc}
  locale={locale}
  title={`${title} — ${t.siteName}`}
  description={tl.placeholderIntro}
  noindex={LEGAL_IS_DRAFT}
>
  <div
    class="mx-auto max-w-[var(--container-prose)] px-[var(--space-gutter)] py-[var(--space-section-y-sm)]"
  >
    <Reveal
      as="article"
      mode="fade"
      class="rounded-2xl border border-line bg-cream px-6 py-10 text-ink shadow-leaf-sm sm:px-10 sm:py-14"
    >
      {
        LEGAL_IS_DRAFT && (
          <div class="mb-8">
            <DraftBanner locale={locale} />
          </div>
        )
      }

      <h1 class="font-display text-h1 text-ink">{title}</h1>
      <p class="text-lead mt-4 text-ink-700">{tl.placeholderIntro}</p>

      <hr class="my-8 border-line" />

      <div class="space-y-8">
        {
          sections.map((section) => (
            <section>
              <h2 class="text-h3 font-semibold text-ink">{section.heading}</h2>
              <p class="text-small mt-2 italic text-ink-500">{tl.todoNote}</p>
            </section>
          ))
        }

        <section>
          <h2 class="text-h3 font-semibold text-ink">{tl.contactHeading}</h2>
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            dir="ltr"
            class="text-small mt-2 inline-block text-primary underline-offset-4 hover:underline"
          >
            {CONTACT_EMAIL}
          </a>
        </section>
      </div>
    </Reveal>
  </div>
</Base>
