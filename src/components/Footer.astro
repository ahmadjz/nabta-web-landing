---
import { getDict, type Locale } from "../i18n";
import { withBase } from "../lib/base";
import { LEGAL_PAIRS } from "../i18n/page-pairs";
import { CONTACT_EMAIL } from "../config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale);
const year = new Date().getFullYear();

// Legal links derive from the page-pair map (the same source the toggle/hreflang
// use). The target page files land in SITE-03; these stable URLs are pinned now.
const legalLinks = LEGAL_PAIRS.map((pair) => ({
  href: withBase(pair[locale]),
  label: t.nav[pair.key as keyof typeof t.nav],
}));
---

<footer class="mt-16 border-t border-neutral-200 bg-neutral-50">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-4 py-10 sm:flex-row sm:items-start sm:justify-between"
  >
    <div>
      <p class="text-lg font-bold text-primary">{t.siteName}</p>
      <p class="mt-1 text-sm text-neutral-600">{t.tagline}</p>
    </div>

    <nav aria-label={t.footer.legal}>
      <p class="text-sm font-semibold text-neutral-900">{t.footer.legal}</p>
      <ul class="mt-2 space-y-1">
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-neutral-700 underline-offset-4 hover:text-primary hover:underline"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div>
      <p class="text-sm font-semibold text-neutral-900">{t.footer.contact}</p>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        dir="ltr"
        class="mt-2 inline-block text-sm text-neutral-700 underline-offset-4 hover:text-primary hover:underline"
      >
        {CONTACT_EMAIL}
      </a>
    </div>
  </div>

  <div class="border-t border-neutral-200 px-4 py-4">
    <p class="mx-auto max-w-5xl text-xs text-neutral-600">
      © {year}
      {t.siteName}. {t.footer.rights}
    </p>
  </div>
</footer>
