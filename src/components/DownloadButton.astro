---
/**
 * The single source of the download-CTA logic, used by Hero + DownloadCTA. Bound
 * to the `PLAY_STORE_URL` config constant:
 *   - empty  ⇒ a DISABLED "coming soon" control (a <span>, role=button,
 *     aria-disabled) with NO href — never a dead store link.
 *   - set    ⇒ a live anchor to the store listing.
 * Flipped to live by setting PLAY_STORE_URL on launch (a neutral brand button for
 * now; the official Google Play badge asset swaps in then per brand-asset rules).
 *
 * LVR-02: refactored to render through `Button.astro` (shared skin + disabled
 * rendering). The `data-download-cta` + `data-state` attrs are the stable test
 * anchor (marketing.test) — they pass straight through Button's `...rest`. Only
 * the skin changed here; the disabled/live LOGIC is untouched.
 */
import { PLAY_STORE_URL } from "../config";
import { getDict, type Locale } from "../i18n";
import Button from "./Button.astro";

interface Props {
  locale: Locale;
  /** Extra classes (e.g. a size bump from the hero). */
  class?: string;
}

const { locale, class: className = "" } = Astro.props;
const t = getDict(locale).marketing.cta;
const isLive = PLAY_STORE_URL.trim() !== "";
---

{
  isLive ? (
    <Button
      variant="primary"
      href={PLAY_STORE_URL}
      target="_blank"
      rel="noopener"
      class={className}
      data-download-cta
      data-state="live"
    >
      {t.label}
    </Button>
  ) : (
    <Button
      disabled
      class={className}
      aria-label={t.ariaComingSoon}
      title={t.ariaComingSoon}
      data-download-cta
      data-state="disabled"
    >
      {t.label}
      <span class="rounded-full bg-surface px-2 py-0.5 text-xs font-bold uppercase tracking-wide text-ink-700">
        {t.comingSoon}
      </span>
    </Button>
  )
}
