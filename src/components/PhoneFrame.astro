---
/**
 * Phone-mockup frame (LVR-TASK-06). A pure-CSS device bezel that wraps a screenshot
 * `<Image>` slot: a `rounded-2xl shadow-leaf-lg` bezel with a sage speaker notch.
 * It is NOT a decorative motif `<svg>` — it's a content frame, so the slotted
 * `<Image>` keeps its own intrinsic width/height (the CLS guard) and lazy-load.
 *
 * Direction-safe: the notch is centred via `inset-x-0 mx-auto` (logical, mirrors
 * cleanly under RTL); the bezel carries no physical-side utilities.
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
  class:list={[
    "relative mx-auto w-full max-w-[16rem] rounded-2xl border border-line bg-surface p-2 shadow-leaf-lg",
    className,
  ]}
>
  {/* Sage speaker notch — a centred pill over the top of the bezel. */}
  <span
    class="absolute inset-x-0 top-3 z-10 mx-auto h-1.5 w-16 rounded-full bg-sage/70"
    aria-hidden="true"></span>
  {/* Clipped screen — the slotted <Image> fills the rounded viewport. */}
  <div class="overflow-hidden rounded-xl">
    <slot />
  </div>
</div>
