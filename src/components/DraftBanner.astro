---
/**
 * The "DRAFT — pending legal review" banner. Rendered on the legal pages only
 * while `LEGAL_IS_DRAFT` (the caller decides). `data-draft-banner` is the stable
 * test anchor; `role="note"` + the clay (terracotta) palette make the draft state
 * obvious to both sighted users and AT — reusing the botanical Card `clay` tokens
 * (LVR-02) so the warning reads as part of the design system, not a stock amber box.
 */
import { getDict, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).legal;
---

<aside
  data-draft-banner
  role="note"
  class="rounded-xl border border-clay-200 bg-clay-100 p-[var(--space-stack)] text-clay-700"
>
  <p class="font-bold">{t.draftBadge}</p>
  <p class="text-small mt-1">{t.draftNote}</p>
</aside>
