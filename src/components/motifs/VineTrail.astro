    d="M52 19c3 3 3 7 1 10-3-2-4-7-1-10Z"
    fill="currentColor"
    stroke="none"
    opacity="0.7"></path>
  <path
    d="M88 13c-3-3-3-7-1-10 3 2 4 7 1 10Z"
    fill="currentColor"
