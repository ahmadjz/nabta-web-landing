---
/** Decorative trailing-vine motif — a wide horizontal run of leaves (LVR-02).
 *  Directional; mirror in RTL with `[dir=rtl]:-scale-x-100` on the wrapper. Stroke
 *  uses `currentColor`. aria-hidden, intrinsic-dimensioned, no a11y role. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

