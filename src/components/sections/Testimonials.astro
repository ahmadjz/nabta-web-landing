---
/**
 * Testimonials (LVR-TASK-06) — editorial quote cards on the warm cream ground. Each
 * card is a `Card` panel with a clay-tinted `QuoteMark` bleeding behind the quote
 * (decorative, aria-hidden, clipped by the card). The featured first card spans two
 * columns on `lg`. The quote sets in the display face, italic, at `text-lead`, with
 * a logical `border-s-2 ps-4` rule; the avatar is a `rounded-full ring-2 ring-sage`
 * astro:assets `<Image>` (intrinsic dims → no CLS). The placeholder badge is
 * clay-toned (`bg-clay-100 text-clay-700`).
 */
import { Image } from "astro:assets";
import Section from "../Section.astro";
import Reveal from "../Reveal.astro";
import Card from "../Card.astro";
import QuoteMark from "../motifs/QuoteMark.astro";
import { getDict, type Locale } from "../../i18n";
// PLACEHOLDER avatar — decorative (alt=""); the name sits in the adjacent text.
// Swapped for real testimonial portraits at launch.
import avatar from "../../assets/avatar-placeholder.png";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.testimonials;
---

<Section tone="cream" width="editorial">
  <div class="max-w-prose">
    <Reveal
      as="h2"
      mode="slide-y"
      class="text-balance font-display text-h2 font-semibold text-ink"
    >
      {t.heading}
    </Reveal>
    <Reveal mode="slide-y" class="mt-3">
      <p class="text-lead text-ink-700">{t.subheading}</p>
    </Reveal>
  </div>

  <Reveal
    mode="stagger"
    class="mt-[var(--space-stack)] grid gap-[var(--space-stack)] sm:grid-cols-2 lg:grid-cols-3"
  >
    {
      t.items.map((item, i) => (
        <Card
          class:list={[
            "relative isolate flex flex-col overflow-hidden",
            i === 0 && "sm:col-span-2 lg:col-span-2",
          ]}
        >
          {/* Clay quote glyph bleeding behind the quote — decorative, clipped. */}
          <QuoteMark class="pointer-events-none absolute -top-3 -start-3 -z-10 w-24 text-clay-100 [dir=rtl]:-scale-x-100" />
          <figure class="flex h-full flex-col">
            <span class="self-start rounded-full bg-clay-100 px-2 py-0.5 text-xs font-medium text-clay-700">
              {t.placeholderBadge}
            </span>
            <blockquote class="mt-4 border-s-2 border-clay-200 ps-4 font-display text-lead italic text-ink">
              {item.quote}
            </blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <Image
                src={avatar}
                alt=""
                width={48}
                height={48}
                loading="lazy"
                class="rounded-full ring-2 ring-sage-200"
              />
              <div>
                <p class="font-semibold text-ink">{item.name}</p>
                <p class="text-small text-ink-700">{item.role}</p>
              </div>
            </figcaption>
          </figure>
        </Card>
      ))
    }
  </Reveal>
</Section>
