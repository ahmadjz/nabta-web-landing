---
import { Image } from "astro:assets";
import { getDict, type Locale } from "../../i18n";
// PLACEHOLDER avatar — decorative (alt=""); the name is in adjacent text. Swapped
// for real testimonials at launch.
import avatar from "../../assets/avatar-placeholder.png";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.testimonials;
---

<section class="border-y border-neutral-100 bg-neutral-50">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <h2 class="text-2xl font-bold text-neutral-900 sm:text-3xl">{t.heading}</h2>
    <p class="mt-3 text-neutral-600">{t.subheading}</p>
    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {
        t.items.map((item) => (
          <figure class="flex flex-col rounded-lg border border-neutral-200 bg-white p-6 shadow-sm">
            <span class="self-start rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">
              {t.placeholderBadge}
            </span>
            <blockquote class="mt-4 border-s-2 border-primary/30 ps-4 text-neutral-700">
              {item.quote}
            </blockquote>
            <figcaption class="mt-5 flex items-center gap-3">
              <Image
                src={avatar}
                alt=""
                width={48}
                height={48}
                loading="lazy"
                class="rounded-full"
              />
              <div>
                <p class="font-semibold text-neutral-900">{item.name}</p>
                <p class="text-sm text-neutral-500">{item.role}</p>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
