---
import { Image } from "astro:assets";
import { getDict, type Locale } from "../../i18n";
// PLACEHOLDER screenshot — astro:assets optimises it (webp, sized). One asset is
// reused across the three slots until real app screenshots land (SITE-04/launch);
// each slot carries its own alt + caption.
import screenshot from "../../assets/app-screenshot-placeholder.png";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.screenshots;
---

<section class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
  <h2 class="text-2xl font-bold text-neutral-900 sm:text-3xl">{t.heading}</h2>
  <p class="mt-3 text-neutral-600">{t.subheading}</p>
  <div class="mt-10 grid gap-8 sm:grid-cols-3">
    {
      t.shots.map((shot) => (
        <figure class="flex flex-col items-center">
          <div class="relative">
            <Image
              src={screenshot}
              alt={shot.alt}
              width={300}
              height={600}
              loading="lazy"
              class="rounded-2xl border border-neutral-200 shadow-sm"
            />
            <span class="absolute start-2 top-2 rounded-full bg-neutral-900/70 px-2 py-0.5 text-xs font-medium text-white">
              {t.placeholderBadge}
            </span>
          </div>
          <figcaption class="mt-4 text-sm font-medium text-neutral-700">
            {shot.caption}
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
