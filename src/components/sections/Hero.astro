---
import { getDict, type Locale } from "../../i18n";
import DownloadButton from "../DownloadButton.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.hero;
---

<section
  class="border-b border-neutral-100 bg-gradient-to-b from-primary/5 to-white"
>
  <div class="mx-auto max-w-5xl px-4 py-20 text-center sm:py-28">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">
      {t.eyebrow}
    </p>
    <h1 class="mt-4 text-4xl font-bold text-neutral-900 sm:text-5xl">
      {t.title}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-700">
      {t.subtitle}
    </p>
    <div class="mt-10 flex justify-center">
      <DownloadButton locale={locale} class="text-lg" />
    </div>
  </div>
</section>
