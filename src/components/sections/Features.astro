---
import { getDict, type Locale } from "../../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.features;
---

<section class="border-y border-neutral-100 bg-neutral-50">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <h2 class="text-2xl font-bold text-neutral-900 sm:text-3xl">{t.heading}</h2>
    <p class="mt-3 max-w-2xl text-neutral-600">{t.subheading}</p>
    <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        t.items.map((item) => (
          <li class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-primary">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-700">
              {item.body}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
