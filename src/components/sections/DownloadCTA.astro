---
/**
 * DownloadCTA (LVR-TASK-07) — the full-bleed forest band. `Section tone="forest"`
 * paints `bg-primary-900 text-cream` AND adds `.forest-band`, which switches the
 * `:focus-visible` ring to cream (global.css) so a focused control stays visible on
 * the dark ground. A low-opacity `MeshGradient` + a corner `LeafCluster` wash the
 * band (decorative, aria-hidden, via the Section `motif` slot).
 *
 * The disabled "coming soon" CTA reuses `DownloadButton` UNCHANGED (its
 * `data-state="disabled"` contract is asserted by marketing.test + contact-cta.test).
 * A secondary GHOST `Button` (a real focusable `<a href="#contact">`) anchors to the
 * Contact section — and is what exercises the forest-band cream focus ring. It uses
 * the ghost (light) variant, NOT clay, because white-on-clay (~3.4:1) fails AA on
 * this band; the light ghost keeps dark-on-light text + a cream ring on the dark.
 *
 * MeshGradient gets a distinct `idSuffix` so its gradient IDs don't collide with the
 * Hero's AmbientBackdrop MeshGradient on the same page (duplicate-id a11y failure).
 */
import Section from "../Section.astro";
import Reveal from "../Reveal.astro";
import Button from "../Button.astro";
import DownloadButton from "../DownloadButton.astro";
import MeshGradient from "../motifs/MeshGradient.astro";
import LeafCluster from "../motifs/LeafCluster.astro";
import { getDict, type Locale } from "../../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.download;
---

<Section tone="forest" width="prose">
  {
    /* Soft mesh wash + corner leaf — decorative, low-opacity, clipped by Section. */
  }
  <MeshGradient
    slot="motif"
    idSuffix="cta"
    class="absolute inset-0 h-full w-full opacity-[0.12]"
  />
  <LeafCluster
    slot="motif"
    class="absolute -bottom-8 -end-8 w-56 text-primary-700/50 [dir=rtl]:-scale-x-100"
  />

  <div class="text-center">
    <Reveal
      as="h2"
      mode="slide-y"
      class="text-balance font-display text-h2 font-semibold text-cream-50"
    >
      {t.heading}
    </Reveal>
    <Reveal mode="slide-y" class="mt-4">
      <p class="mx-auto max-w-xl text-lead text-cream-50/85">{t.body}</p>
    </Reveal>

    <Reveal
      mode="stagger"
      class="mt-8 flex flex-wrap items-center justify-center gap-4"
    >
      <DownloadButton locale={locale} />
      <Button variant="ghost" href="#contact">{t.secondaryLabel}</Button>
    </Reveal>

    <p class="mt-4 text-small text-cream-50/70">{t.note}</p>
  </div>
</Section>
