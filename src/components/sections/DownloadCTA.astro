---
import { getDict, type Locale } from "../../i18n";
import DownloadButton from "../DownloadButton.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDict(locale).marketing.download;
---

<section class="border-t border-neutral-100 bg-primary/5">
  <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:py-20">
    <h2 class="text-2xl font-bold text-neutral-900 sm:text-3xl">{t.heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-neutral-700">{t.body}</p>
    <div class="mt-8 flex justify-center">
      <DownloadButton locale={locale} />
    </div>
    <p class="mt-4 text-sm text-neutral-600">{t.note}</p>
  </div>
</section>
