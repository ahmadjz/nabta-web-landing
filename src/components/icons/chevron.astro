---
/** Line-art chevron icon (LVR-02) — points in the reading direction, so it mirrors
 *  in RTL via the built-in `rtl:` variant. 24×24, `currentColor` stroke.
 *  aria-hidden, intrinsic-dimensioned, no a11y role. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class:list={["rtl:-scale-x-100", className]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="m9 6 6 6-6 6"></path>
</svg>
