---
/** Line-art phone-handset icon (LVR-02). Conditionally rendered in LVR-07 (only
 *  when CONTACT_PHONE is set). 24×24, `currentColor` stroke. aria-hidden,
 *  intrinsic-dimensioned, no a11y role. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path
    d="M5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 3 6.2 2 2 0 0 1 5 4Z"
  ></path>
</svg>
