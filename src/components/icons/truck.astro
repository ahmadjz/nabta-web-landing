---
/** Line-art delivery-truck icon (LVR-02). Directional — the cab faces the reading
 *  direction, so it mirrors in RTL via the built-in `rtl:` variant. 24×24,
 *  `currentColor` stroke. aria-hidden, intrinsic-dimensioned, no a11y role. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class:list={["rtl:-scale-x-100", className]}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M2 6h11v9H2z"></path>
  <path d="M13 9h4l3 3v3h-7z"></path>
  <circle cx="7" cy="18" r="1.6"></circle>
  <circle cx="17" cy="18" r="1.6"></circle>
</svg>
