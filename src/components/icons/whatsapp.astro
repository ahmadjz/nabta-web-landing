---
/** Line-art WhatsApp icon (LVR-02) — a chat bubble with a handset. Conditionally
 *  rendered in LVR-07 (only when CONTACT_WHATSAPP is set). 24×24, `currentColor`
 *  stroke. aria-hidden, intrinsic-dimensioned, no a11y role. */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M3 21l1.6-4.2A8 8 0 1 1 8 19.4L3 21Z"></path>
  <path
    d="M9 8c0 4 3 7 7 7 1-1 1.2-1.8 0-2.5-.8-.5-1.5-.9-2.2-.2-.5.5-1 .4-1.6 0-.8-.6-1.3-1.1-1.8-1.9-.4-.6-.5-1.1 0-1.6.7-.7.3-1.4-.2-2.2C9.8 5.8 9 6 8 7c-.4.3-1 .5-1 1Z"
  ></path>
</svg>
