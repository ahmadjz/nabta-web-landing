---
/**
 * Decorative ambient backdrop (LVR-02): a soft CSS/SVG mesh-gradient wash plus a
 * capped set (6) of slowly-drifting leaf silhouettes. Entirely out of flow
 * (`absolute inset-0`) + `pointer-events-none` + `aria-hidden` → zero layout
 * impact, zero CLS, invisible to assistive tech. The drift animation is collapsed
 * to instant by the global prefers-reduced-motion block.
 *
 * Positions/sizes are STATIC (no random) so server + client render identically.
 */
import MeshGradient from "./motifs/MeshGradient.astro";
import Frond from "./motifs/Frond.astro";
import LeafCluster from "./motifs/LeafCluster.astro";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

// Capped at 6 leaves. `inset` is the logical inline-start offset (RTL-safe).
const LEAVES = [
  { top: "6%", inset: "8%", size: "5rem", delay: "0s", dur: "11s" },
  { top: "20%", inset: "76%", size: "3.5rem", delay: "1.5s", dur: "13s" },
  { top: "52%", inset: "12%", size: "4rem", delay: "0.8s", dur: "12s" },
  { top: "66%", inset: "80%", size: "6rem", delay: "2.2s", dur: "15s" },
  { top: "82%", inset: "28%", size: "3rem", delay: "1.1s", dur: "10s" },
  { top: "38%", inset: "54%", size: "4.5rem", delay: "3s", dur: "14s" },
];
---

<div
  class:list={[
    "ambient-backdrop pointer-events-none absolute inset-0 -z-10 overflow-hidden",
    className,
  ]}
  aria-hidden="true"
>
  <MeshGradient class="absolute inset-0 h-full w-full" />
  {
    LEAVES.map((leaf, i) => (
      <span
        class="ambient-leaf absolute block text-sage-200/60"
        style={`top:${leaf.top};inset-inline-start:${leaf.inset};inline-size:${leaf.size};animation-delay:${leaf.delay};animation-duration:${leaf.dur};`}
      >
        {i % 2 === 0 ? (
          <Frond class="h-full w-full" />
        ) : (
          <LeafCluster class="h-full w-full" />
        )}
      </span>
    ))
  }
</div>
