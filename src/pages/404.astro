---
import Base from "../layouts/Base.astro";
import { getDict } from "../i18n";
import { withBase } from "../lib/base";

// 404 is locale-agnostic — GitHub Pages serves /404.html for any unknown path.
// Show both languages; the shell defaults to ar (RTL). noindex (no pair → no
// hreflang). The link strategy still routes home through withBase().
const ar = getDict("ar");
const en = getDict("en");
---

<Base
  pageKey="notfound"
  locale="ar"
  title={`404 — ${ar.siteName}`}
  description={ar.notFound.body}
  noindex
>
  <section class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28">
    <p class="text-6xl font-bold text-primary">404</p>

    <div class="mt-6" dir="rtl">
      <h1 class="text-2xl font-bold">{ar.notFound.title}</h1>
      <p class="mt-2 text-neutral-600">{ar.notFound.body}</p>
      <a
        href={withBase("/")}
        class="mt-3 inline-block font-medium text-primary underline underline-offset-4"
      >
        {ar.notFound.backHome}
      </a>
    </div>

    <hr class="mx-auto my-8 max-w-xs border-neutral-200" />

    <div dir="ltr">
      <h2 class="text-2xl font-bold">{en.notFound.title}</h2>
      <p class="mt-2 text-neutral-600">{en.notFound.body}</p>
      <a
        href={withBase("/en/")}
        class="mt-3 inline-block font-medium text-primary underline underline-offset-4"
      >
        {en.notFound.backHome}
      </a>
    </div>
  </section>
</Base>
