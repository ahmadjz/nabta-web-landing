---
import Base from "../layouts/Base.astro";
import Reveal from "../components/Reveal.astro";
import { getDict } from "../i18n";
import { withBase } from "../lib/base";

// 404 is locale-agnostic — GitHub Pages serves /404.html for any unknown path.
// Show both languages; the shell defaults to ar (RTL). noindex (no pair → no
// hreflang). The link strategy still routes home through withBase().
const ar = getDict("ar");
const en = getDict("en");

const homeLink =
  "text-body mt-4 inline-block font-medium text-primary underline underline-offset-4 transition-colors duration-[var(--dur-fast)] hover:text-primary-700";
---

<Base
  pageKey="notfound"
  locale="ar"
  title={`404 — ${ar.siteName}`}
  description={ar.notFound.body}
  noindex
>
  <Reveal
    as="section"
    mode="fade"
    class="mx-auto max-w-[var(--container-prose)] px-[var(--space-gutter)] py-[var(--space-section-y)] text-center"
  >
    <p class="font-display text-display leading-none text-primary">404</p>

    <div class="mt-8" dir="rtl">
      <h1 class="text-h2 font-bold text-ink">{ar.notFound.title}</h1>
      <p class="text-lead mt-3 text-ink-700">{ar.notFound.body}</p>
      <a href={withBase("/")} class={homeLink}>
        {ar.notFound.backHome}
      </a>
    </div>

    <hr class="mx-auto my-10 max-w-xs border-line" />

    <div dir="ltr">
      <h2 class="text-h2 font-bold text-ink">{en.notFound.title}</h2>
      <p class="text-lead mt-3 text-ink-700">{en.notFound.body}</p>
      <a href={withBase("/en/")} class={homeLink}>
        {en.notFound.backHome}
      </a>
    </div>
  </Reveal>
</Base>
